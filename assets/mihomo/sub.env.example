# mihomo 订阅地址 —— 本地文件，勿提交 git (.gitignore 已排除 sub.env)
#
# 用法:
#   cp sub.env.example sub.env
#   vim sub.env        # 填入你的订阅地址
#
# bootstrap.sh 首次运行若无 sub.env，会交互生成。
# start-proxy.sh 会 source 本文件 (set -a)，所以只写 VAR=value，勿加 shell 危险语法。

# 主订阅 (必填)
SUB_URL_1="https://your-provider.example/sub/token"

# 备订阅 (可选，留空或整行删掉)
SUB_URL_2="https://your-backup.example/api/v1/client/subscribe?token=xxxx"
